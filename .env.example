# Copy this file to .env and fill in your values
# cp .env.example .env

# Required
OPENAI_API_KEY=your_openai_api_key_here

# Optional — enables AI workflow tracing in LangSmith
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=ai-mvp-dev
LANGCHAIN_TRACING_V2=true

# Optional — used as contact email for Crossref/NCBI API politeness headers
CROSSREF_MAILTO=your_email@example.com

# Optional — enables Semantic Scholar API (higher rate limits)
S2_API_KEY=your_semantic_scholar_api_key_here

# Optional — enables Google Scholar search via SerpAPI
SERPAPI_KEY=your_serpapi_key_here

# Database (defaults to local SQLite if not set)
DATABASE_URL=sqlite:///app.db
# DATABASE_URL=postgresql://user:password@localhost:5432/evidence_db
